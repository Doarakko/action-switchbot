{
  "name": "action-switchbot",
  "version": "1.0.0",
  "private": true,
  "description": "Operate SwitchBot using GitHub Actions.",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "biome format --write .",
    "format-check": "biome format .",
    "lint": "biome lint .",
    "check": "biome check .",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run build && npm run check && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Doarakko/action-switchbot"
  },
  "keywords": [
    "actions",
    "node",
    "switchbot"
  ],
  "author": "Doarakko",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.0",
    "axios": "^0.30.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^25.3.0",
    "@vercel/ncc": "^0.38.0",
    "jest": "^30.2.0",
    "js-yaml": "^4.1.1",
    "ts-jest": "^29.4.6",
    "typescript": "^4.4.4"
  }
}
